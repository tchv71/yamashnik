{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": ["--port=/dev/ttyUSB0", "--cpm"],
      "stopAtEntry": true,
      "externalConsole": false,
      "cwd": "/home/tchv/yamashnik/sw/spyvspy",
      "program": "/home/tchv/yamashnik/sw/spyvspy/build/msxnet",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}